# ── 基础镜像 ────────────────────────────────────────────────
# python:3.10-slim 是官方精简版，去掉了编译工具链，体积约 130 MB。
# 与本地开发环境的 Python 3.10.11 保持大版本一致，避免语法兼容问题。
FROM python:3.10-slim

# ── 工作目录 ────────────────────────────────────────────────
# 容器内所有后续命令（COPY / RUN / CMD）的默认路径。
# 目录不存在时 Docker 会自动创建。
WORKDIR /app

# ── 安装依赖（独立一层，利用构建缓存）───────────────────────
# 先只复制依赖清单，不复制业务代码。
# 好处：代码改动时不会触发 pip install 重新执行，构建更快。
COPY requirements-app.txt .

# --no-cache-dir：不在镜像里保留 pip 下载缓存，减小镜像体积。
RUN pip install --no-cache-dir -r requirements-app.txt

# ── 复制业务代码 ─────────────────────────────────────────────
# 只复制运行所需的单个脚本，不把整个项目目录打包进去。
# .env 文件不复制进镜像——密码不应固化在镜像层里，
# 运行时通过 docker-compose 的 env_file 注入。
COPY lesson5-2.py .

# ── 容器启动命令 ─────────────────────────────────────────────
# CMD 是容器的默认入口，可被 docker run 末尾的参数覆盖。
# 使用列表形式（exec 模式）而非字符串形式，
# 确保 Python 进程 PID=1，能正确接收 SIGTERM 信号。
CMD ["python", "lesson5-2.py"]
